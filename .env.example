# Application Settings
DATABASE_PATH=house_hunter.db
ENVIRONMENT=local # local or production
MASTER_PASSWORD=admin
ALLOWED_ORIGINS=http://localhost:3000,https://your-house-hunter.vercel.app

# Scraping & Filtering Constraints
MAX_RENT=45000
TARGET_BHK=3 BHK

# Commute & Logistics Configurations
TARGET_DESTINATION_NAME=Bagmane Constellation, Bangalore
TARGET_LAT=12.9822462
TARGET_LNG=77.699052
TARGET_ARRIVAL_TIME=13:00
MAX_COMMUTE_DURATION_MINS=60

# External Integrations
GOOGLE_MAPS_API_KEY=your_google_maps_key_here
SUPABASE_URL=your_supabase_url_here
# SUPABASE_KEY MUST be the service_role key (NOT the anon key). RLS on the
# properties table has no INSERT policy, so the anon key silently blocks every
# sync write and no rows land. Proper write policies are tracked as Cycle 5.
SUPABASE_KEY=your_supabase_service_role_key_here
